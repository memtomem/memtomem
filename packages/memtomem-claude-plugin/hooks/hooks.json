{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "mm search \"${prompt}\" --top-k 3 --format context 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "mm index \"${tool_input.file_path}\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "mm add \"Session ended: $(date '+%Y-%m-%d %H:%M')\" --tags session,auto 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
