{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "uv",
            "args": ["run", "--no-project", "python", "${CLAUDE_PLUGIN_ROOT}/bin/hook_dispatch.py", "SessionStart"],
            "timeout": 8,
            "statusMessage": "memtomem · checking automation dependency"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "uv",
            "args": ["run", "--no-project", "python", "${CLAUDE_PLUGIN_ROOT}/bin/hook_dispatch.py", "UserPromptSubmit"],
            "timeout": 8,
            "statusMessage": "memtomem · searching relevant memories"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "uv",
            "args": ["run", "--no-project", "python", "${CLAUDE_PLUGIN_ROOT}/bin/hook_dispatch.py", "PostToolUse"],
            "timeout": 12,
            "statusMessage": "memtomem · queueing changed file"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "uv",
            "args": ["run", "--no-project", "python", "${CLAUDE_PLUGIN_ROOT}/bin/hook_dispatch.py", "Stop"],
            "timeout": 12,
            "statusMessage": "memtomem · flushing index queue"
          }
        ]
      }
    ]
  }
}
